{
  // ── Editor ───────────────────────────────────────────────────────────────
  "editor.acceptSuggestionOnCommitCharacter": false,
  "editor.bracketPairColorization.enabled": true,
  "editor.cursorBlinking": "solid",
  "editor.cursorSmoothCaretAnimation": "off",
  "editor.cursorStyle": "line",
  "editor.cursorWidth": 2,
  "editor.fontFamily": "'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.formatOnPaste": false,
  "editor.formatOnSave": true,
  "editor.glyphMargin": true,
  "editor.guides.bracketPairs": true,
  "editor.guides.indentation": true,
  "editor.linkedEditing": true,
  "editor.minimap.enabled": false,
  "editor.mouseWheelScrollSensitivity": 1,
  "editor.multiCursorModifier": "alt",
  "editor.occurrencesHighlight": "singleFile",
  "editor.renderLineHighlight": "all",
  "editor.renderWhitespace": "selection",
  "editor.roundedSelection": false,
  "editor.scrollBeyondLastLine": false,
  "editor.selectionHighlight": true,
  "editor.smoothScrolling": true,
  "editor.snippetSuggestions": "inline",
  "editor.stickyScroll.enabled": true,
  "editor.suggest.localityBonus": true,
  "editor.suggestSelection": "first",
  "editor.tabCompletion": "on",
  "editor.tabSize": 2,
  "editor.wordSeparators": "/\\()\"':,.;<>~!@#$%^&*|+=[]{}`?-",

  // ── Line numbers (relative for Vim-like navigation) ─────────────────────
  "editor.lineNumbers": "relative",
  "editor.renderLineNumbers": true,

  // ── Files ────────────────────────────────────────────────────────────────
  "files.autoSave": "off",
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,

  // ── Workbench ────────────────────────────────────────────────────────────
  "workbench.colorTheme": "Catppuccin Mocha",
  "workbench.iconTheme": "catppuccin-mocha",
  "workbench.list.smoothScrolling": true,
  "workbench.startupEditor": "none",
  "workbench.tree.indent": 20,
  "workbench.tree.renderIndentGuides": "always",

  // ── Window ───────────────────────────────────────────────────────────────
  "window.commandCenter": false,
  "window.titleBarStyle": "custom",

  // ── Extensions ───────────────────────────────────────────────────────────
  // vscode-neovim integration
  "vscode-neovim.neovimClean": false,
  "vscode-neovim.compositeKeys": {
    "jj": {
      "command": "vscode-neovim.escape"
    }
  },

  // Ctrl keys passed through to Neovim in insert mode
  "vscode-neovim.ctrlKeysForInsertMode": [
    "a",
    "d",
    "h",
    "j",
    "m",
    "o",
    "r",
    "t",
    "u",
    "w"
  ],

  // Ctrl keys passed through to Neovim in normal mode
  "vscode-neovim.ctrlKeysForNormalMode": [
    "a",
    "b",
    "d",
    "e",
    "f",
    "h",
    "i",
    "j",
    "k",
    "l",
    "m",
    "o",
    "r",
    "t",
    "u",
    "v",
    "w",
    "x",
    "y",
    "z",
    "/",
    "]"
  ],

  // Scroll settings to match Neovim feel
  "editor.mouseWheelZoom": true,
  "editor.scrollbar.horizontalScrollbarSize": 8,
  "editor.scrollbar.verticalScrollbarSize": 8,

  // Use VS Code's undo — Neovim undo inside VS Code is problematic
  "vscode-neovim.useCtrlKeysForInsertMode": true,

  // Set Neovim path for macOS
  "vscode-neovim.neovimExecutablePaths.darwin": "/opt/homebrew/bin/nvim",

  // Highlight groups to match our Catppuccin theme
  "vscode-neovim.highlightGroups.highlights": {
    "Cursor": {
      "color": "rgba(255, 255, 255, 0.8)",
      "backgroundColor": "rgba(203, 166, 247, 0.3)"
    },
    "Visual": {
      "backgroundColor": "rgba(137, 180, 250, 0.15)"
    },
    "VisualNOS": {
      "backgroundColor": "rgba(137, 180, 250, 0.1)"
    },
    "Search": {
      "backgroundColor": "rgba(250, 227, 156, 0.3)"
    },
    "IncSearch": {
      "backgroundColor": "rgba(250, 227, 156, 0.5)"
    },
    "Substitute": {
      "backgroundColor": "rgba(250, 179, 135, 0.4)"
    }
  },

  // Hide some editor UI that Neovim handles internally
  "editor.hideCursorInOverviewRuler": true,
  "editor.overviewRulerBorder": false,

  // ── Language-specific overrides ──────────────────────────────────────────
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[markdown]": {
    "editor.defaultFormatter": "yzhang.markdown-all-in-one",
    "editor.formatOnSave": false,
    "editor.unicodeHighlight.ambiguousCharacters": false,
    "editor.wordWrap": "on"
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  }
}
